<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
  <!-- Suppress Javadoc checks for internal packages -->
  <suppress checks="JavadocType|MissingJavadocType|JavadocMethod|MissingJavadocMethod"
            files=".*[\/]internal[\/].*"/>

  <!-- Suppress Javadoc checks for the base package (SandboxApplication etc.) -->
  <suppress checks="JavadocType|MissingJavadocType|JavadocMethod|MissingJavadocMethod"
            files="com[\/]gurch[\/]sandbox[\/][^\/]*\.java"/>
</suppressions>
