<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:fluxnova="http://camunda.org/schema/1.0/bpmn"
  id="Definitions_SimpleUserTask"
  targetNamespace="http://gurch.com/sandbox/process">
  <bpmn:process
    id="simpleUserTaskProcess"
    name="Simple User Task Process"
    isExecutable="true"
    fluxnova:historyTimeToLive="180">
    <bpmn:startEvent id="startEvent">
      <bpmn:outgoing>flow_start_to_user_task</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="approveTask" name="Approve Request">
      <bpmn:extensionElements>
        <fluxnova:taskListener
          event="create"
          delegateExpression="${requestTaskLifecycleListener}" />
        <fluxnova:taskListener
          event="complete"
          delegateExpression="${requestTaskLifecycleListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_to_user_task</bpmn:incoming>
      <bpmn:outgoing>flow_user_task_to_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="endEvent">
      <bpmn:extensionElements>
        <fluxnova:executionListener
          event="end"
          delegateExpression="${requestProcessCompletionListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_user_task_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_to_user_task" sourceRef="startEvent" targetRef="approveTask"/>
    <bpmn:sequenceFlow id="flow_user_task_to_end" sourceRef="approveTask" targetRef="endEvent"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_SimpleUserTask">
    <bpmndi:BPMNPlane id="BPMNPlane_SimpleUserTask" bpmnElement="simpleUserTaskProcess">
      <bpmndi:BPMNShape id="Shape_StartEvent" bpmnElement="startEvent">
        <dc:Bounds x="180" y="117" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ApproveTask" bpmnElement="approveTask">
        <dc:Bounds x="270" y="95" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent" bpmnElement="endEvent">
        <dc:Bounds x="430" y="117" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_StartToTask" bpmnElement="flow_start_to_user_task">
        <di:waypoint x="216" y="135"/>
        <di:waypoint x="270" y="135"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_TaskToEnd" bpmnElement="flow_user_task_to_end">
        <di:waypoint x="370" y="135"/>
        <di:waypoint x="430" y="135"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
