# Hostname used by application containers to reach PostgreSQL.
POSTGRES_HOST=localhost
# PostgreSQL TCP port.
POSTGRES_PORT=5432
# Database username used by the app.
POSTGRES_USER=sandbox
# Database password used by the app.
POSTGRES_PASSWORD=changeme
# Primary application database name.
POSTGRES_DB=sandboxdb
# Host port used to expose Adminer UI.
ADMINER_PORT=8085
# Directory where JWT signing keys are persisted.
AUTH_JWT_KEYS_DIR=/var/lib/sandbox/keys
# Active JWT key id used for signing new tokens.
AUTH_JWT_ACTIVE_KEY_ID=sandbox-rsa-key-v1
# Comma-separated JWT key ids accepted for verification only.
AUTH_JWT_RETIRED_KEY_IDS=
# Bootstrap admin password used in local/dev environments.
AUTH_BOOTSTRAP_PASSWORD=AdminPass123!

# Copy this file to .env and update secrets before running docker-compose
